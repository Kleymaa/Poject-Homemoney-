{
  "name": "home-budget-backend",
  "version": "1.0.0",
  "description": "Backend API for HomeBudget project on Node.js, Express.js, TypeScript and PostgreSQL",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node-pg-migrate up -j ts -m migrations",
    "migrate:down": "node-pg-migrate down -j ts -m migrations",
    "migrate:create": "node-pg-migrate create -j ts -m migrations"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-pg-migrate": "^7.9.1",
    "nodemailer": "^8.0.2",
    "pdfkit": "^0.16.0",
    "pg": "^8.13.1",
    "swagger-ui-express": "^5.0.1",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/web-push": "^3.6.4",
    "dotenv-cli": "^11.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "test": "jest --runInBand",
  "test:watch": "jest --watch"
}
